{
  $schema: 'https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json',

  appId: 'com.v1.cafeteria-web',
  productName: 'cafeteria',
  asar: true,
  directories: {
    output: 'release/${version}'
  },
  files: ['dist', 'dist-electron'],
  publish: [
    {
      provider: 'github',
      owner: 'vendys-kyuseok',
      repo: 'electron-cafeteria-web',
      releaseType: 'release'
    }
  ],
  win: {
    target: [
      {
        target: 'nsis',
        arch: ['x64']
      }
    ],
    artifactName: '${productName}-Windows-${version}-Setup.${ext}'
    // "icon": "resources/windows/ic_sik.ico"
  },
  nsis: {
    oneClick: true,
    perMachine: true,
    shortcutName: '구내식당',
    language: 1042,
    allowElevation: true,
    deleteAppDataOnUninstall: true,
    allowToChangeInstallationDirectory: false
    // "installerHeaderIcon": "resources/windows/ic_sik.ico"
  },
  mac: {
    target: ['dmg'],
    category: 'public.app-category.graphics-design'
    // "icon": "resources/osx/Apple.icns"
  },
  dmg: {
    // "icon": "resources/osx/Apple.icns",
    background: null
  }
}
